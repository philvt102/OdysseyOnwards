---
import "../styles/global.css";
import systems from "../cms/systems.json";
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>Odyssey Onwards</title>
    </head>
    <body>
        <div id="header">
            <div id="titlebox">
                <h1 id="title">Odyssey Onwards</h1>
                <div id="RHtitle">
                    <div id="links">
                        <a href="" title="Visit the Real Arcade Museum"
                            >Delmarcade</a
                        >
                        <a href="" title="Repairs / Sales">videogameCRASH</a>
                        <a href="">About</a>
                    </div>
                    <input type="search" placeholder="search" />
                </div>
            </div>
            <p id="headerDesc">A Virtual Home Video Game Hardware Museum</p>

            <div
                style="display: flex; justify-content:center; align-items: center; 12px; margin-bottom: 12px;"
            >
                <!-- The Master Toggle sitting inline, acting as a dedicated first column element -->
                <div class="toggle-container-wrapper">
                    <label class="toggle-switch">
                        <!-- Removed the 'checked' attribute so it boots turned off on page load -->
                        <input type="checkbox" id="layout-toggle-switch" />
                        <span class="toggle-slider"></span>
                        <span class="toggle-label">Select All</span>
                    </label>
                </div>
                <fieldset id="selectBox">
                    <ul id="checks">
                        <li>
                            <input
                                type="checkbox"
                                id="console"
                                name="selection"
                                value="console"
                                checked
                            />
                            <label for="console"> Consoles</label>
                        </li>
                        <li>
                            <input
                                type="checkbox"
                                id="addon"
                                name="selection"
                                value="addon"
                            />
                            <label for="addon"> Add-ons</label>
                        </li>

                        <li>
                            <input
                                type="checkbox"
                                id="tabletop"
                                name="selection"
                                value="tabletop"
                            />
                            <label for="tabletop"> Tabletop Systems</label>
                        </li>
                        <li>
                            <input
                                type="checkbox"
                                id="micro"
                                name="selection"
                                value="micro"
                            />
                            <label for="micro"> Microcomputers</label>
                        </li>
                        <li>
                            <input
                                type="checkbox"
                                id="pong"
                                name="selection"
                                value="pong"
                            />
                            <label for="pong"> Pong Consoles</label>
                        </li>
                        <li>
                            <input
                                type="checkbox"
                                id="handheld"
                                name="selection"
                                value="handheld"
                            />
                            <label for="handheld"> Handhelds</label>
                        </li>

                        <li>
                            <input
                                type="checkbox"
                                id="pnp"
                                name="selection"
                                value="pnp"
                            />
                            <label for="pnp"> Plug and Play</label>
                        </li>
                        <li>
                            <input
                                type="checkbox"
                                id="other"
                                name="selection"
                                value="other"
                            />
                            <label for="other"> Other</label>
                        </li>
                    </ul>
                </fieldset>
            </div>

            <fieldset id="buttons">
                <div id="years">
                    <!-- Added class="decade-btn" explicitly to each element below -->
                    <input
                        type="button"
                        id="70"
                        class="decade-btn"
                        data-decade="1970"
                        value="1970s"
                    />
                    <input
                        type="button"
                        id="80"
                        class="decade-btn"
                        data-decade="1980"
                        value="1980s"
                    />
                    <input
                        type="button"
                        id="90"
                        class="decade-btn"
                        data-decade="1990"
                        value="1990s"
                    />
                    <input
                        type="button"
                        id="00"
                        class="decade-btn"
                        data-decade="2000"
                        value="2000s"
                    />
                    <input
                        type="button"
                        id="10"
                        class="decade-btn"
                        data-decade="2010"
                        value="2010s"
                    />
                    <input
                        type="button"
                        id="20"
                        class="decade-btn"
                        data-decade="2020"
                        value="2020s"
                    />
                </div>
                <div id="manu">
                    <input
                        type="button"
                        id="atari"
                        class="manu-btn"
                        data-manu="Atari"
                        value="Atari"
                    />
                    <input
                        type="button"
                        id="nintendo"
                        class="manu-btn"
                        data-manu="Nintendo"
                        value="Nintendo"
                    />
                    <input
                        type="button"
                        id="sega"
                        class="manu-btn"
                        data-manu="Sega"
                        value="Sega"
                    />
                    <input
                        type="button"
                        id="sony"
                        class="manu-btn"
                        data-manu="Sony"
                        value="Sony"
                    />
                    <input
                        type="button"
                        id="microsoft"
                        class="manu-btn"
                        data-manu="Microsoft"
                        value="Microsoft"
                    />
                    <input
                        type="button"
                        id="else"
                        class="manu-btn"
                        data-manu="Everything Else"
                        value="Everything Else"
                    />
                </div>

                <!-- The target drop wrapper box remains right below the layout arrays -->
                <div id="dropdown-menu" class="dropdown hidden"></div>
            </fieldset>
        </div>

        <div id="gallery">
            <!-- JavaScript will dynamically inject the track and filtered images here -->
            <div
                id="gallery-container-target"
                class="gallery-track"
                style="width: 100%; height: 100%;"
            >
            </div>
        </div>
    </body>
</html>

<script define:vars={{ systems }}>
    // --- SAFE DATA TYPE INGESTION FORCE-PATCH ---
    const verifiedSystems =
        typeof systems === "string" ? JSON.parse(systems) : systems;

    const dropdown = document.getElementById("dropdown-menu");
    const checkboxes = document.querySelectorAll(
        '#checks input[type="checkbox"]',
    );
    const decadeButtons = document.querySelectorAll(".decade-btn");
    const manuButtons = document.querySelectorAll(".manu-btn");
    const galleryTarget = document.getElementById("gallery-container-target");

    let activeDecade = null;
    let activeManu = null;
    let hoverTimeout = null;

    function getCheckedTypes() {
        return Array.from(checkboxes)
            .filter((cb) => cb.checked)
            .map((cb) => cb.value);
    }

    function parseJsonTypes(typeString) {
        if (!typeString) return [];
        return typeString
            .replace(/[\[\]]/g, "")
            .split(",")
            .map((t) => t.trim());
    }

    function passesTypeCheck(item, checkedTypes) {
        const itemTypes = parseJsonTypes(item.type);
        if (checkedTypes.includes("other")) {
            const knownTypes = [
                "console",
                "addon",
                "tabletop",
                "micro",
                "pong",
                "handheld",
                "pnp",
            ];
            if (!itemTypes.some((t) => knownTypes.includes(t))) return true;
        }
        return itemTypes.some((t) => checkedTypes.includes(t));
    }

    function renderDynamicGallery() {
        const checkedTypes = getCheckedTypes();

        const filteredImages = verifiedSystems
            .filter(
                (item) => passesTypeCheck(item, checkedTypes) && item.mainImg,
            )
            .map((item) => item.mainImg);

        if (filteredImages.length === 0) {
            galleryTarget.innerHTML = displayList
                .map(
                    (imgSrc) =>
                        `<img src="${imgSrc}" alt="Museum Hardware" draggable="false" />`,
                )
                .join("");
            galleryTarget.style.animation = "none";
            return;
        }

        const displayList = [...filteredImages, ...filteredImages];

        // 1. Force kill the active animation state instantly
        galleryTarget.style.animation = "none";

        // 2. Inject the image tags cleanly into the DOM window
        galleryTarget.innerHTML = displayList
            .map(
                (imgSrc) =>
                    `<img src="${imgSrc}" alt="Museum Hardware" draggable="false" />`,
            )
            .join("");

        const totalImages = galleryTarget.querySelectorAll("img");
        let loadedCount = 0;

        // 3. Define the mathematical calculation engine
        function calculateExactTrackVelocity() {
            let calculatedTrackWidth = 0;
            const targetHeight = 240; // 80% of your #gallery height (300px * 0.8 = 240px)
            const elementGap = 20; // The 20px gap from your CSS layout rule

            // Loop through the unique images (the first half of our duplicated list)
            // to manually calculate how wide the track is in physical pixels
            for (let i = 0; i < totalImages.length / 2; i++) {
                const img = totalImages[i];

                // Proportional Width Calculation = (Natural Width / Natural Height) * Display Height
                const imageAspectRatio = img.naturalWidth / img.naturalHeight;
                let computedImageWidth = imageAspectRatio * targetHeight;

                // Respect the CSS max-width constraint if you have one active
                if (computedImageWidth > 330) computedImageWidth = 330;

                // Add the image width and its layout spacing gap to the running total
                calculatedTrackWidth += computedImageWidth + elementGap;
            }

            // CONTROL RIG: Set your pixels-per-second speed limit here
            const pixelsPerSecond = 100; // Set this high (like 60 or 100) to explicitly confirm control!

            // Duration = Total physical width of one complete loop sequence / speed
            const exactDuration = calculatedTrackWidth / pixelsPerSecond;

            // Inject the variable into the CSS scope cleanly
            galleryTarget.style.setProperty(
                "--scroll-speed",
                `${exactDuration}s`,
            );

            // Push the animation loop back live after a microtask tick
            setTimeout(() => {
                galleryTarget.style.animation =
                    "slideLeft var(--scroll-speed) infinite linear";
            }, 10);
        }

        // 4. Safely monitor image load lifecycles
        totalImages.forEach((img) => {
            if (img.complete && img.naturalWidth > 0) {
                loadedCount++;
                if (loadedCount === totalImages.length)
                    calculateExactTrackVelocity();
            } else {
                img.addEventListener("load", () => {
                    loadedCount++;
                    if (loadedCount === totalImages.length)
                        calculateExactTrackVelocity();
                });
                img.addEventListener("error", () => {
                    loadedCount++;
                    if (loadedCount === totalImages.length)
                        calculateExactTrackVelocity();
                });
            }
        });
    }

    // --- Decade Layout Generator ---
    function buildDecadeHTML(startYear) {
        let html = "";
        const checkedTypes = getCheckedTypes();

        for (let year = startYear; year < startYear + 10; year++) {
            const matches = verifiedSystems.filter((item) => {
                const releaseYear = parseInt(item.releaseYear, 10);
                return (
                    releaseYear === year && passesTypeCheck(item, checkedTypes)
                );
            });

            html += `
                <div class="dropdown-col">
                    <h4>${year}</h4>
                    <div class="col-links">
                        ${matches.length > 0 ? matches.map((item) => `<a href="#${item.name.replace(/\s+/g, "-")}">${item.name}</a>`).join("") : `<span class="no-systems">—</span>`}
                    </div>
                </div>
            `;
        }
        return html;
    }

    function buildManuHTML(manufacturerName) {
        const checkedTypes = getCheckedTypes();
        const topFiveBrands = [
            "atari",
            "nintendo",
            "sega",
            "sony",
            "microsoft",
        ];
        const matchingSystems = verifiedSystems.filter((systemObj) =>
            passesTypeCheck(systemObj, checkedTypes),
        );

        if (manufacturerName === "Everything Else") {
            const uniqueManus = new Set();
            matchingSystems.forEach((systemObj) => {
                const rawManu = systemObj.manufacturer
                    ? String(systemObj.manufacturer).trim()
                    : "";
                if (rawManu) {
                    const manuLower = rawManu.toLowerCase();
                    if (!topFiveBrands.includes(manuLower)) {
                        uniqueManus.add(rawManu);
                    }
                }
            });

            const sortedManus = Array.from(uniqueManus).sort((a, b) =>
                a.localeCompare(b),
            );

            return `
                <div class="dropdown-col" style="border-right: none;">
                    <h4>Other Brands</h4>
                    <div class="col-links">
                        ${sortedManus.length > 0 ? sortedManus.map((manu) => `<a href="#${manu.toLowerCase().replace(/\s+/g, "-")}">${manu}</a>`).join("") : `<span class="no-systems">No matching brands</span>`}
                    </div>
                </div>
            `;
        }

        const brandMatches = matchingSystems.filter((systemObj) => {
            const itemManu = systemObj.manufacturer
                ? String(systemObj.manufacturer).trim()
                : "";
            return (
                itemManu.toLowerCase() === manufacturerName.toLowerCase().trim()
            );
        });

        return `
            <div class="dropdown-col" style="border-right: none;">
                <h4>${manufacturerName}</h4>
                <div class="col-links">
                    ${brandMatches.length > 0 ? brandMatches.map((systemObj) => `<a href="#${systemObj.name.replace(/\s+/g, "-")}">${systemObj.name}</a>`).join("") : `<span class="no-systems">No matching systems</span>`}
                </div>
            </div>
        `;
    }

    // --- Hover Management: Decades ---
    decadeButtons.forEach((btn) => {
        btn.addEventListener("mouseenter", (e) => {
            clearTimeout(hoverTimeout);
            activeManu = null;
            activeDecade = parseInt(e.target.dataset.decade, 10);
            dropdown.style.left = "";
            dropdown.style.width = "";
            dropdown.classList.remove("single-col");
            dropdown.innerHTML = buildDecadeHTML(activeDecade);
            dropdown.classList.remove("hidden");
        });
        btn.addEventListener("mouseleave", () => {
            clearTimeout(hoverTimeout);
            hoverTimeout = setTimeout(
                () => dropdown.classList.add("hidden"),
                200,
            );
        });
    });

    // --- Hover Management: Manufacturers ---
    manuButtons.forEach((btn) => {
        btn.addEventListener("mouseenter", (e) => {
            clearTimeout(hoverTimeout);
            activeDecade = null;
            activeManu = e.target.dataset.manu;
            dropdown.classList.add("single-col");
            dropdown.innerHTML = buildManuHTML(activeManu);

            const parentElement = document.getElementById("buttons");
            const parentRect = parentElement.getBoundingClientRect();
            const btnRect = e.target.getBoundingClientRect();
            const offsetLeft = btnRect.left - parentRect.left;

            dropdown.style.left = `${offsetLeft}px`;
            dropdown.style.width = "250px";
            dropdown.classList.remove("hidden");
        });
        btn.addEventListener("mouseleave", () => {
            clearTimeout(hoverTimeout);
            hoverTimeout = setTimeout(
                () => dropdown.classList.add("hidden"),
                200,
            );
        });
    });

    dropdown.addEventListener("mouseenter", () => clearTimeout(hoverTimeout));
    dropdown.addEventListener("mouseleave", () => {
        clearTimeout(hoverTimeout);
        hoverTimeout = setTimeout(() => dropdown.classList.add("hidden"), 200);
    });

    // --- Dynamic Checkbox Handling Updates ---
    checkboxes.forEach((cb) => {
        cb.addEventListener("change", () => {
            renderDynamicGallery(); // Triggers gallery layout generation instantly
            if (dropdown.classList.contains("hidden")) return;
            if (activeDecade)
                dropdown.innerHTML = buildDecadeHTML(activeDecade);
            if (activeManu) dropdown.innerHTML = buildManuHTML(activeManu);
        });
    });

    // --- Inverted Toggle Engine ---
    const layoutToggle = document.getElementById("layout-toggle-switch");

    layoutToggle.addEventListener("change", (e) => {
        const isSelectAll = e.target.checked;
        checkboxes.forEach((cb) => {
            cb.checked = isSelectAll ? true : cb.value === "console";
        });

        renderDynamicGallery(); // Update engine
        if (dropdown.classList.contains("hidden")) return;
        if (activeDecade) dropdown.innerHTML = buildDecadeHTML(activeDecade);
        if (activeManu) dropdown.innerHTML = buildManuHTML(activeManu);
    });

    checkboxes.forEach((cb) => {
        cb.addEventListener("change", () => {
            const allChecked = Array.from(checkboxes).every(
                (item) => item.checked,
            );
            if (allChecked && !layoutToggle.checked) {
                layoutToggle.checked = true;
            } else if (!allChecked && layoutToggle.checked) {
                layoutToggle.checked = false;
            }
        });
    });

    // --- INITIALIZATION INITIAL BOOTSTRAP RUN ---
    renderDynamicGallery();

    // --- BULLETPROOF CAROUSEL MOUSE DRAG & CLICK ENGINE ---
    let isDragging = false;
    let startX = 0;
    let clickStartX = 0;
    let currentTranslate = 0;
    let previousTranslate = 0;

    const galleryWrapper = document.getElementById("gallery");

    // Block native HTML5 image extraction clone popups completely
    galleryWrapper.addEventListener("dragstart", (e) => e.preventDefault());

    galleryWrapper.addEventListener("mousedown", (e) => {
        // Only engage tracking on standard left click
        if (e.button !== 0) return;

        isDragging = true;
        clickStartX = e.pageX;

        // 1. Capture the exact pixel transform offset the track is at right now
        const computedStyle = window.getComputedStyle(galleryTarget);
        const matrix = new WebKitCSSMatrix(computedStyle.transform);

        // 2. Set our initial tracking values
        previousTranslate = matrix.m41;
        startX = e.pageX - previousTranslate;

        // 3. Clear active animation entirely so it doesn't fight your cursor updates
        galleryTarget.style.animation = "none";
        galleryTarget.style.transform = `translateX(${previousTranslate}px)`;
    });

    window.addEventListener("mousemove", (e) => {
        if (!isDragging) return;

        // Calculate translation delta relative to your initial mouse offset anchor
        currentTranslate = e.pageX - startX;

        const halfTrackWidth = galleryTarget.scrollWidth / 2;

        // INFINITE WARPING: Warp smoothly if dragging past tracking thresholds
        if (currentTranslate > 0) {
            currentTranslate -= halfTrackWidth;
            startX += halfTrackWidth;
        } else if (currentTranslate < -halfTrackWidth) {
            currentTranslate += halfTrackWidth;
            startX -= halfTrackWidth;
        }

        // Push positions live onto screen layout transforms instantly
        galleryTarget.style.transform = `translateX(${currentTranslate}px)`;
    });

    window.addEventListener("mouseup", (e) => {
        if (!isDragging) return;
        isDragging = false;

        const dragDistance = Math.abs(e.pageX - clickStartX);

        // A true intentional click (moved less than 6px) handles navigation target anchors
        if (dragDistance < 6) {
            const clickedImg = e.target.closest("img");
            if (clickedImg) {
                const imageSrc = clickedImg.getAttribute("src");
                const matchedSystem = verifiedSystems.find(
                    (item) => item.mainImg === imageSrc,
                );
                if (matchedSystem) {
                    window.location.hash = matchedSystem.name.replace(
                        /\s+/g,
                        "-",
                    );
                }
            }
        }

        // 4. RESTORE CAROUSEL ENGINE: Calculate track values back out to CSS scope seamlessly
        // This prevents the track from teleporting back to zero when animation loops pick up
        const totalImages = galleryTarget.querySelectorAll("img");
        if (totalImages.length > 0) {
            let calculatedTrackWidth = 0;
            const targetHeight = 240;
            const elementGap = 20;

            for (let i = 0; i < totalImages.length / 2; i++) {
                const img = totalImages[i];
                const imageAspectRatio = img.naturalWidth / img.naturalHeight;
                let computedImageWidth = imageAspectRatio * targetHeight;
                if (computedImageWidth > 330) computedImageWidth = 330;
                calculatedTrackWidth += computedImageWidth + elementGap;
            }

            const pixelsPerSecond = 100;
            const exactDuration = calculatedTrackWidth / pixelsPerSecond;
            galleryTarget.style.setProperty(
                "--scroll-speed",
                `${exactDuration}s`,
            );

            // Apply keyframe loops starting exactly where you let go of your track drag
            const currentPercentage =
                (currentTranslate / calculatedTrackWidth) * 100;

            // Re-apply animation smoothly using a brief microtask tick delay
            setTimeout(() => {
                galleryTarget.style.animation = `slideLeft var(--scroll-speed) infinite linear`;
            }, 10);
        }
    });
</script>

<!-- 1. The is:inline attribute forces Astro to preserve this CSS exactly as written -->
<style is:inline>
    #buttons {
        position: relative; /* The single parent anchor context */
    }

    .dropdown {
        display: grid !important;
        grid-template-columns: repeat(10, minmax(0, 1fr)) !important;
        gap: 0.5rem;
        position: absolute;
        top: calc(100% + 8px) !important;
        left: 0;
        width: 100%;
        box-sizing: border-box;
        background: #1a1a1a;
        border: 1px solid #333;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.65);
        padding: 1rem;
        z-index: 1000;
        border-radius: 4px;
    }

    .dropdown::before {
        content: "";
        position: absolute;
        top: -12px;
        left: 0;
        width: 100%;
        height: 12px;
        background: transparent !important;
    }

    .hidden {
        display: none !important;
    }

    .dropdown.single-col {
        grid-template-columns: 1fr !important;
        width: 250px !important;
    }

    /* Ensure the column container spans the full 250px bounds */
    .dropdown.single-col .dropdown-col {
        display: flex !important;
        flex-direction: column !important;
        width: 100% !important;
        border: none !important; /* Strips out any internal dividing borders */
        padding: 0 !important;
    }

    .dropdown.single-col .col-links {
        display: flex !important;
        flex-direction: column !important;
        width: 100% !important;
    }

    .dropdown.single-col .col-links a {
        display: block !important;
        width: 100% !important;
        text-align: center !important;
        /* Keeps names readable even if they are slightly longer */
        text-overflow: clip !important;
        overflow: visible !important;
    }

    .dropdown.single-col::before {
        content: "";
        position: absolute;
        /* Spans the full width of your 250px manufacturer column menu */
        left: 0;
        width: 100%;

        /* Extends upward by 15px to cover the gap between the button row and the menu box */
        top: -15px;
        height: 15px;

        background: transparent !important; /* Stays completely invisible to the user */
        z-index: -1; /* Sits cleanly behind the main text contents layout */
    }

    #dropdown-menu.single-col {
        display: block;
        max-height: 450px; /* Adjust height based on your design limits */
        overflow-y: auto; /* Turns on vertical scrolling only when needed */
        overflow-x: hidden;
    }

    /* Optional: Styled scroll track for a modern layout aesthetic */
    #dropdown-menu.single-col::-webkit-scrollbar {
        width: 6px;
    }
    #dropdown-menu.single-col::-webkit-scrollbar-thumb {
        background: #444;
        border-radius: 4px;
    }
    #dropdown-menu.single-col::-webkit-scrollbar-thumb:hover {
        background: #666;
    }

    .hidden {
        display: none !important;
    }

    .dropdown-col {
        display: flex !important;
        flex-direction: column !important;
        align-items: center !important;
        border-right: 1px solid #2d2d2d;
        padding: 0 4px;
        min-width: 0;
    }

    .dropdown-col:last-child {
        border-right: none;
    }

    .dropdown-col h4 {
        margin: 0 0 0.5rem 0 !important;
        font-size: 0.95rem !important;
        color: #ff9900 !important; /* Orange Headers */
        border-bottom: 1px solid #444 !important;
        padding-bottom: 2px !important;
        width: 100% !important;
        text-align: center !important;
    }

    .col-links {
        display: flex !important;
        flex-direction: column !important;
        gap: 0.4rem !important;
        width: 100% !important;
        text-align: center !important;
    }

    .col-links a {
        color: #00bcff !important;
        font-size: 0.8rem !important;
        text-decoration: none !important;
        display: block !important;
        width: 100% !important;
        white-space: nowrap !important;
        overflow: hidden !important;
        text-overflow: ellipsis !important;
    }

    .col-links a:hover {
        text-decoration: underline !important;
        color: #fff !important;
    }

    .no-systems {
        color: #555 !important;
        font-size: 0.8rem;
        text-align: center;
    }

    #gallery {
        overflow: hidden;
        display: flex;
        position: absolute;
        width: 100%;
        height: 300px;
        cursor: grab;
        user-select: none !important;
        -webkit-user-select: none !important;
        -moz-user-select: none !important;
    }

    .gallery-track {
        display: flex !important;
        flex-direction: row !important;
        width: max-content !important;
        height: 100% !important;
        align-items: center !important;
        gap: 20px;
        will-change: transform;
    }

    #gallery img {
        user-select: none !important;
        -webkit-user-drag: none !important;
        pointer-events: auto !important;
        cursor: pointer;
    }

    #gallery:active {
        cursor: grabbing;
    }

    #gallery img:active {
        cursor: grabbing;
    }
    
    #gallery:hover #gallery-container-target {
        animation-play-state: paused !important;
    }

    .gallery-track:hover {
        animation-play-state: paused;
    }

    .gallery-track img {
        max-width: 330px;
        height: auto;
    }

    @keyframes slideLeft {
        from {
            transform: translateX(0);
        }
        to {
            transform: translateX(-50%);
        }
    }

    /* Container Layout */
    .filter-row {
