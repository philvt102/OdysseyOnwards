---
import "../styles/global.css";
import systems from "../cms/systems.json";
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>Odyssey Onwards</title>
    </head>
    <body>
        <div id="header">
            <div id="titlebox">
                <h1 id="title">Odyssey Onwards</h1>
                <div id="RHtitle">
                    <div id="links">
                        <a href="" title="Visit the Real Arcade Museum"
                            >Delmarcade</a
                        >
                        <a href="" title="Repairs / Sales">videogameCRASH</a>
                        <a href="">About</a>
                    </div>
                    <input type="search" placeholder="search" />
                </div>
            </div>
            <p id="headerDesc">A Virtual Home Video Game Hardware Museum</p>

            <div
                style="display: flex; justify-content:center; align-items: center; 12px; margin-bottom: 12px;"
            >
                <!-- The Master Toggle sitting inline, acting as a dedicated first column element -->
                <div class="toggle-container-wrapper">
                    <label class="toggle-switch">
                        <!-- Removed the 'checked' attribute so it boots turned off on page load -->
                        <input type="checkbox" id="layout-toggle-switch" />
                        <span class="toggle-slider"></span>
                        <span class="toggle-label">Select All</span>
                    </label>
                </div>
                <fieldset id="selectBox">
                    <ul id="checks">
                        <li>
                            <input
                                type="checkbox"
                                id="console"
                                name="selection"
                                value="console"
                                checked
                            />
                            <label for="console"> Consoles</label>
                        </li>
                        <li>
                            <input
                                type="checkbox"
                                id="addon"
                                name="selection"
                                value="addon"
                            />
                            <label for="addon"> Add-ons</label>
                        </li>

                        <li>
                            <input
                                type="checkbox"
                                id="tabletop"
                                name="selection"
                                value="tabletop"
                            />
                            <label for="tabletop"> Tabletop Systems</label>
                        </li>
                        <li>
                            <input
                                type="checkbox"
                                id="micro"
                                name="selection"
                                value="micro"
                            />
                            <label for="micro"> Microcomputers</label>
                        </li>
                        <li>
                            <input
                                type="checkbox"
                                id="pong"
                                name="selection"
                                value="pong"
                            />
                            <label for="pong"> Pong Consoles</label>
                        </li>
                        <li>
                            <input
                                type="checkbox"
                                id="handheld"
                                name="selection"
                                value="handheld"
                            />
                            <label for="handheld"> Handhelds</label>
                        </li>

                        <li>
                            <input
                                type="checkbox"
                                id="pnp"
                                name="selection"
                                value="pnp"
                            />
                            <label for="pnp"> Plug and Play</label>
                        </li>
                        <li>
                            <input
                                type="checkbox"
                                id="other"
                                name="selection"
                                value="other"
                            />
                            <label for="other"> Other</label>
                        </li>
                    </ul>
                </fieldset>
            </div>

            <fieldset id="buttons">
                <div id="years">
                    <!-- Added class="decade-btn" explicitly to each element below -->
                    <input
                        type="button"
                        id="70"
                        class="decade-btn"
                        data-decade="1970"
                        value="1970s"
                    />
                    <input
                        type="button"
                        id="80"
                        class="decade-btn"
                        data-decade="1980"
                        value="1980s"
                    />
                    <input
                        type="button"
                        id="90"
                        class="decade-btn"
                        data-decade="1990"
                        value="1990s"
                    />
                    <input
                        type="button"
                        id="00"
                        class="decade-btn"
                        data-decade="2000"
                        value="2000s"
                    />
                    <input
                        type="button"
                        id="10"
                        class="decade-btn"
                        data-decade="2010"
                        value="2010s"
                    />
                    <input
                        type="button"
                        id="20"
                        class="decade-btn"
                        data-decade="2020"
                        value="2020s"
                    />
                </div>
                <div id="manu">
                    <input
                        type="button"
                        id="atari"
                        class="manu-btn"
                        data-manu="Atari"
                        value="Atari"
                    />
                    <input
                        type="button"
                        id="nintendo"
                        class="manu-btn"
                        data-manu="Nintendo"
                        value="Nintendo"
                    />
                    <input
                        type="button"
                        id="sega"
                        class="manu-btn"
                        data-manu="Sega"
                        value="Sega"
                    />
                    <input
                        type="button"
                        id="sony"
                        class="manu-btn"
                        data-manu="Sony"
                        value="Sony"
                    />
                    <input
                        type="button"
                        id="microsoft"
                        class="manu-btn"
                        data-manu="Microsoft"
                        value="Microsoft"
                    />
                    <input
                        type="button"
                        id="else"
                        class="manu-btn"
                        data-manu="Everything Else"
                        value="Everything Else"
                    />
                </div>

                <!-- The target drop wrapper box remains right below the layout arrays -->
                <div id="dropdown-menu" class="dropdown hidden"></div>
            </fieldset>
        </div>

        <div id="gallery">
            <div class="gallery-track">
                <img src="/img/odysseyMain.webp" />
                <img src="/img/channelFMain.webp" />
                <img src="/img/2600lightSixerMain.webp" />
                <img src="/img/intellivisionMain.webp" />
                <img src="/img/colorTVGameBlockKazushiMain.webp" />
                <img src="img/400Main.webp" />
                <img src="/img/colecovisionMain.webp" />
                <img src="/img/52004portMain.webp" />
                <img src="/img/famicomMain.webp" />
                <img src="/img/masterSystemMain.webp" />
                <img src="/img/NESmain.webp" />
                <img src="/img/gameBoyMain.webp" />
                <img src="/img/segaCDMain.webp" />
                <img src="/img/virtualBoyMain.webp" />
                <img src="/img/namco5in1ArcadeClassics.webp" />
                <img src="/img/odysseyMain.webp" />
                <img src="/img/channelFMain.webp" />
                <img src="/img/2600lightSixerMain.webp" />
                <img src="/img/intellivisionMain.webp" />
                <img src="/img/colorTVGameBlockKazushiMain.webp" />
                <img src="img/400Main.webp" />
                <img src="/img/colecovisionMain.webp" />
                <img src="/img/52004portMain.webp" />
                <img src="/img/famicomMain.webp" />
                <img src="/img/masterSystemMain.webp" />
                <img src="/img/NESmain.webp" />
                <img src="/img/gameBoyMain.webp" />
                <img src="/img/segaCDMain.webp" />
                <img src="/img/virtualBoyMain.webp" />
                <img src="/img/namco5in1ArcadeClassics.webp" />
            </div>
        </div>
    </body>
</html>

<script define:vars={{ systems }}>
    // --- SAFE DATA TYPE INGESTION FORCE-PATCH ---
    // If Astro bundled 'systems' as a raw text string, parse it cleanly back into an object array
    const verifiedSystems =
        typeof systems === "string" ? JSON.parse(systems) : systems;

    const dropdown = document.getElementById("dropdown-menu");
    const checkboxes = document.querySelectorAll(
        '#checks input[type="checkbox"]',
    );
    const decadeButtons = document.querySelectorAll(".decade-btn");
    const manuButtons = document.querySelectorAll(".manu-btn");

    let activeDecade = null;
    let activeManu = null;
    let hoverTimeout = null;

    function getCheckedTypes() {
        return Array.from(checkboxes)
            .filter((cb) => cb.checked)
            .map((cb) => cb.value);
    }

    function parseJsonTypes(typeString) {
        if (!typeString) return [];
        return typeString
            .replace(/[\[\]]/g, "")
            .split(",")
            .map((t) => t.trim());
    }

    function passesTypeCheck(item, checkedTypes) {
        const itemTypes = parseJsonTypes(item.type);
        if (checkedTypes.includes("other")) {
            const knownTypes = [
                "console",
                "addon",
                "tabletop",
                "micro",
                "pong",
                "handheld",
                "pnp",
            ];
            if (!itemTypes.some((t) => knownTypes.includes(t))) return true;
        }
        return itemTypes.some((t) => checkedTypes.includes(t));
    }

    // --- Decade Layout Generator ---
    function buildDecadeHTML(startYear) {
        let html = "";
        const checkedTypes = getCheckedTypes();

        for (let year = startYear; year < startYear + 10; year++) {
            const matches = verifiedSystems.filter((item) => {
                const releaseYear = parseInt(item.releaseYear, 10);
                return (
                    releaseYear === year && passesTypeCheck(item, checkedTypes)
                );
            });

            html += `
                <div class="dropdown-col">
                    <h4>${year}</h4>
                    <div class="col-links">
                        ${
                            matches.length > 0
                                ? matches
                                      .map(
                                          (item) =>
                                              `<a href="#${item.name.replace(/\s+/g, "-")}">${item.name}</a>`,
                                      )
                                      .join("")
                                : `<span class="no-systems">—</span>`
                        }
                    </div>
                </div>
            `;
        }
        return html;
    }

    function buildManuHTML(manufacturerName) {
        const checkedTypes = getCheckedTypes();
        const topFiveBrands = [
            "atari",
            "nintendo",
            "sega",
            "sony",
            "microsoft",
        ];

        // 1. Gather all systems passing the checkbox filters
        const matchingSystems = verifiedSystems.filter((systemObj) =>
            passesTypeCheck(systemObj, checkedTypes),
        );

        // 2. Handle the "Everything Else" Unique Brand List
        if (manufacturerName === "Everything Else") {
            const uniqueManus = new Set();

            matchingSystems.forEach((systemObj) => {
                const rawManu = systemObj.manufacturer
                    ? String(systemObj.manufacturer).trim()
                    : "";
                if (rawManu) {
                    const manuLower = rawManu.toLowerCase();
                    // Exclude the big five brands
                    if (!topFiveBrands.includes(manuLower)) {
                        uniqueManus.add(rawManu); // Keeps original casing for display
                    }
                }
            });

            // Convert Set back to an alphabetized array
            const sortedManus = Array.from(uniqueManus).sort((a, b) =>
                a.localeCompare(b),
            );

            return `
            <div class="dropdown-col" style="border-right: none;">
                <h4>Other Brands</h4>
                <div class="col-links">
                    ${
                        sortedManus.length > 0
                            ? sortedManus
                                  .map((manu) => {
                                      // Creates a URL slug like #magnavox or #coleco
                                      const slug = manu
                                          .toLowerCase()
                                          .replace(/\s+/g, "-");
                                      return `<a href="#${slug}">${manu}</a>`;
                                  })
                                  .join("")
                            : `<span class="no-systems">No matching brands</span>`
                    }
                </div>
            </div>
        `;
        }

        // 3. Fallback: Original logic for individual Top 5 brand dropdowns
        const brandMatches = matchingSystems.filter((systemObj) => {
            const itemManu = systemObj.manufacturer
                ? String(systemObj.manufacturer).trim()
                : "";
            return (
                itemManu.toLowerCase() === manufacturerName.toLowerCase().trim()
            );
        });

        return `
        <div class="dropdown-col" style="border-right: none;">
            <h4>${manufacturerName}</h4>
            <div class="col-links">
                ${
                    brandMatches.length > 0
                        ? brandMatches
                              .map(
                                  (systemObj) =>
                                      `<a href="#${systemObj.name.replace(/\s+/g, "-")}">${systemObj.name}</a>`,
                              )
                              .join("")
                        : `<span class="no-systems">No matching systems</span>`
                }
            </div>
        </div>
    `;
    }

    // --- Hover Management: Decades ---
    decadeButtons.forEach((btn) => {
        btn.addEventListener("mouseenter", (e) => {
            clearTimeout(hoverTimeout);
            activeManu = null;
            activeDecade = parseInt(e.target.dataset.decade, 10);

            dropdown.style.left = "";
            dropdown.style.width = "";
            dropdown.classList.remove("single-col");

            dropdown.innerHTML = buildDecadeHTML(activeDecade);
            dropdown.classList.remove("hidden");
        });

        btn.addEventListener("mouseleave", () => {
            // Clear any old timers before starting a new one
            clearTimeout(hoverTimeout);
            hoverTimeout = setTimeout(
                () => dropdown.classList.add("hidden"),
                200,
            );
        });
    });

    // --- Hover Management: Manufacturers ---
    manuButtons.forEach((btn) => {
        btn.addEventListener("mouseenter", (e) => {
            clearTimeout(hoverTimeout);
            activeDecade = null;
            activeManu = e.target.dataset.manu;

            dropdown.classList.add("single-col");
            dropdown.innerHTML = buildManuHTML(activeManu);

            const parentElement = document.getElementById("buttons");
            const parentRect = parentElement.getBoundingClientRect();
            const btnRect = e.target.getBoundingClientRect();

            const offsetLeft = btnRect.left - parentRect.left;

            dropdown.style.left = `${offsetLeft}px`;
            dropdown.style.width = "250px";

            dropdown.classList.remove("hidden");
        });

        btn.addEventListener("mouseleave", () => {
            // Clear any old timers before starting a new one
            clearTimeout(hoverTimeout);
            hoverTimeout = setTimeout(
                () => dropdown.classList.add("hidden"),
                200,
            );
        });
    });

    // --- Hover Management: The Dropdown Container Window Itself ---
    dropdown.addEventListener("mouseenter", () => {
        // If the mouse moves inside the menu, cancel the closing countdown instantly
        clearTimeout(hoverTimeout);
    });

    dropdown.addEventListener("mouseleave", () => {
        // FIX: Clear any old loops and use a matching 200ms delay to close safely
        clearTimeout(hoverTimeout);
        hoverTimeout = setTimeout(() => dropdown.classList.add("hidden"), 200);
    });

    // --- Dynamic Checkbox Handling Updates ---
    checkboxes.forEach((cb) => {
        cb.addEventListener("change", () => {
            if (dropdown.classList.contains("hidden")) return;
            if (activeDecade)
                dropdown.innerHTML = buildDecadeHTML(activeDecade);
            if (activeManu) dropdown.innerHTML = buildManuHTML(activeManu);
        });
    });

    // --- Inverted Toggle Engine: Default Off ---
    const layoutToggle = document.getElementById("layout-toggle-switch");

    function forceLayoutRedraw() {
        if (dropdown.classList.contains("hidden")) return;
        if (activeDecade) dropdown.innerHTML = buildDecadeHTML(activeDecade);
        if (activeManu) dropdown.innerHTML = buildManuHTML(activeManu);
    }

    layoutToggle.addEventListener("change", (e) => {
        const isSelectAll = e.target.checked;

        checkboxes.forEach((cb) => {
            if (isSelectAll) {
                // Checked (ON): Activate every single checkbox
                cb.checked = true;
            } else {
                // Unchecked (OFF): Drop everything except 'console'
                cb.checked = cb.value === "console";
            }
        });

        forceLayoutRedraw();
    });

    // Dynamic sync: If a user changes sub-boxes manually, recalculate
    // whether the master switch needs to toggle on or off.
    checkboxes.forEach((cb) => {
        cb.addEventListener("change", () => {
            const allChecked = Array.from(checkboxes).every(
                (item) => item.checked,
            );

            if (allChecked && !layoutToggle.checked) {
                layoutToggle.checked = true;
            } else if (!allChecked && layoutToggle.checked) {
                layoutToggle.checked = false;
            }
        });
    });
</script>

<!-- 1. The is:inline attribute forces Astro to preserve this CSS exactly as written -->
<style is:inline>
    #buttons {
        position: relative; /* The single parent anchor context */
    }

    .dropdown {
        display: grid !important;
        grid-template-columns: repeat(10, minmax(0, 1fr)) !important;
        gap: 0.5rem;
        position: absolute;
        top: calc(100% + 8px) !important;
        left: 0;
        width: 100%;
        box-sizing: border-box;
        background: #1a1a1a;
        border: 1px solid #333;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.65);
        padding: 1rem;
        z-index: 1000;
        border-radius: 4px;
    }

    .dropdown::before {
        content: "";
        position: absolute;
        top: -12px;
        left: 0;
        width: 100%;
        height: 12px;
        background: transparent !important;
    }

    .hidden {
        display: none !important;
    }

    .dropdown.single-col {
        grid-template-columns: 1fr !important;
        width: 250px !important;
    }

    /* Ensure the column container spans the full 250px bounds */
    .dropdown.single-col .dropdown-col {
        display: flex !important;
        flex-direction: column !important;
        width: 100% !important;
        border: none !important; /* Strips out any internal dividing borders */
        padding: 0 !important;
    }

    .dropdown.single-col .col-links {
        display: flex !important;
        flex-direction: column !important;
        width: 100% !important;
    }

    .dropdown.single-col .col-links a {
        display: block !important;
        width: 100% !important;
        text-align: center !important;
        /* Keeps names readable even if they are slightly longer */
        text-overflow: clip !important;
        overflow: visible !important;
    }

    .dropdown.single-col::before {
        content: "";
        position: absolute;
        /* Spans the full width of your 250px manufacturer column menu */
        left: 0;
        width: 100%;

        /* Extends upward by 15px to cover the gap between the button row and the menu box */
        top: -15px;
        height: 15px;

        background: transparent !important; /* Stays completely invisible to the user */
        z-index: -1; /* Sits cleanly behind the main text contents layout */
    }

    #dropdown-menu.single-col {
        display: block;
        max-height: 450px; /* Adjust height based on your design limits */
        overflow-y: auto; /* Turns on vertical scrolling only when needed */
        overflow-x: hidden;
    }

    /* Optional: Styled scroll track for a modern layout aesthetic */
    #dropdown-menu.single-col::-webkit-scrollbar {
        width: 6px;
    }
    #dropdown-menu.single-col::-webkit-scrollbar-thumb {
        background: #444;
        border-radius: 4px;
    }
    #dropdown-menu.single-col::-webkit-scrollbar-thumb:hover {
        background: #666;
    }

    .hidden {
        display: none !important;
    }

    .dropdown-col {
        display: flex !important;
        flex-direction: column !important;
        align-items: center !important;
        border-right: 1px solid #2d2d2d;
        padding: 0 4px;
        min-width: 0;
    }

    .dropdown-col:last-child {
        border-right: none;
    }

    .dropdown-col h4 {
        margin: 0 0 0.5rem 0 !important;
        font-size: 0.95rem !important;
        color: #ff9900 !important; /* Orange Headers */
        border-bottom: 1px solid #444 !important;
        padding-bottom: 2px !important;
        width: 100% !important;
        text-align: center !important;
    }

    .col-links {
        display: flex !important;
        flex-direction: column !important;
        gap: 0.4rem !important;
        width: 100% !important;
        text-align: center !important;
    }

    .col-links a {
        color: #00bcff !important;
        font-size: 0.8rem !important;
        text-decoration: none !important;
        display: block !important;
        width: 100% !important;
        white-space: nowrap !important;
        overflow: hidden !important;
        text-overflow: ellipsis !important;
    }

    .col-links a:hover {
        text-decoration: underline !important;
        color: #fff !important;
    }

    .no-systems {
        color: #555 !important;
        font-size: 0.8rem;
        text-align: center;
    }

    #gallery {
        overflow: hidden;
        display: flex;
        width: 100%; /* Ensure your gallery has a defined width */
    }

    .gallery-track {
        display: flex;
        animation: slideLeft 30s infinite linear;
        /* Pause on hover optional */
    }

    .gallery-track:hover {
        animation-play-state: paused;
    }

    .gallery-track img {
        width: 300px; /* Set a fixed width or percentage for your images */
        flex-shrink: 0;
    }

    @keyframes slideLeft {
        from {
            transform: translateX(0);
        }
        to {
            transform: translateX(-50%);
        }
    }

    /* Container Layout */
    .filter-row {
        background: #151515;
        padding: 8px 12px;
        border-radius: 6px;
        border: 1px solid #2d2d2d;
    }

    /* The Switch Shell */
    .toggle-switch {
        position: relative;
        display: flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
        user-select: none;
        font-size: 0.8rem;
        color: #888;
    }

    /* Hide Native Checkbox Box */
    .toggle-switch input {
        opacity: 0;
        width: 0;
        height: 0;
        position: absolute;
    }

    /* Slider Track Track */
    .toggle-slider {
        position: relative;
        width: 36px;
        height: 20px;
        background-color: #333;
        border: 1px solid #444;
        transition: 0.2s ease-in-out;
        border-radius: 20px;
    }

    /* Moving Knob Handle */
    .toggle-slider::before {
        position: absolute;
        content: "";
        height: 12px;
        width: 12px;
        left: 3px;
        bottom: 3px;
        background-color: #555;
        transition: 0.2s ease-in-out;
        border-radius: 50%;
    }

    /* Active State Colors */
    .toggle-switch input:checked + .toggle-slider {
        background-color: #00bcff22;
        border-color: #3584e4;
    }

    .toggle-switch input:checked + .toggle-slider::before {
        background-color: #3584e4;
        transform: translateX(16px);
    }

    .toggle-switch input:checked ~ .toggle-label {
        color: #3584e4;
    }
</style>
